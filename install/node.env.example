# UHRK telemetry node environment
# Copy to /etc/uhrk/node.env or let install_node.sh generate it.

UHRK_DEVICE_ID=0
UHRK_RADIO_FREQ_MHZ=868.1
UHRK_SIGNAL_BANDWIDTH=125000
UHRK_CODING_RATE=5
UHRK_SPREADING_FACTOR=10
UHRK_PREAMBLE_LENGTH=8
UHRK_SYNC_WORD=52
UHRK_TX_POWER=20

UHRK_CADENCE_SECONDS=1.0
UHRK_LAUNCH_READY_CADENCE_SECONDS=0.45
UHRK_LAUNCH_READY_DEVICE_SLOT_SECONDS=0.12

UHRK_NODE_CONTROL_HOST=0.0.0.0
UHRK_NODE_CONTROL_PORT=8091
UHRK_FLIGHT_LOG_DIR=/home/uhrk/flight_logs
UHRK_GRAVITY=9.80665
UHRK_BURN_ACTIVE_ACC_THRESHOLD=15.0
UHRK_BURN_OUT_ACC_THRESHOLD=3.0
UHRK_LAUNCH_CONFIRM_SAMPLES=3
UHRK_MIN_LAUNCH_ALTITUDE_DELTA=8.0
UHRK_STAGE_SEP_ALTITUDE=3000.0
UHRK_DROGUE_DROP_ALT=50.0
UHRK_MAIN_DEPLOY_ALTITUDE=500.0
UHRK_LANDED_ALTITUDE=5.0
UHRK_LANDED_VSPEED_THRESHOLD=1.0
