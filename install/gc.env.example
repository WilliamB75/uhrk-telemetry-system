# UHRK ground station environment
# Copy to /etc/uhrk/gc.env or let install_gc.sh generate it.

UHRK_UDP_HOST=127.0.0.1
UHRK_UDP_PORT=1700
UHRK_GROUND_GPS_PORT=/dev/ttyAMA0
UHRK_CONTROL_HOST=0.0.0.0
UHRK_CONTROL_PORT=8090
UHRK_FLIGHT_LOG_DIR=/opt/uhrk/uhrk_site/flight_logs
UHRK_SETTINGS_FILE=/opt/uhrk/uhrk_site/event_settings.json
UHRK_ALTITUDE_ZERO_FILE=/opt/uhrk/uhrk_site/altitude_zero.json
UHRK_SHUTDOWN_PHRASE="SHUTDOWN UHRK"

UHRK_LORA_DOWNLINK_FREQ_MHZ=868.1
UHRK_LORA_DOWNLINK_POWER_DBM=14
UHRK_LORA_DOWNLINK_DATARATE=SF10BW125
UHRK_LORA_DOWNLINK_CODING_RATE=4/5
UHRK_LORA_DOWNLINK_PREAMBLE=8
UHRK_LORA_DOWNLINK_REPEATS=3
UHRK_LORA_DOWNLINK_REPEAT_DELAY_S=1.0

# Optional WiFi/HTTP node API used for bench time sync only.
UHRK_NODE_TIME_SYNC_URLS=http://10.42.0.78:8091/api/time-sync
